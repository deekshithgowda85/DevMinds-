generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  debugSessions   DebugSession[]
  learningMetrics LearningMetric?

  @@map("users")
}

model DebugSession {
  id              String   @id @default(cuid())
  userId          String
  language        String
  codeSnippet     String
  errorMessage    String
  errorType       String
  conceptGap      String?
  explanation     String?
  fix             String?
  confidenceLevel Float    @default(0)
  vectorId        String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, errorType])
  @@map("debug_sessions")
}

model LearningMetric {
  id                 String   @id @default(cuid())
  userId             String   @unique
  totalSessions      Int      @default(0)
  recurringMistakes  Json     @default("[]")
  conceptWeaknesses  Json     @default("[]")
  improvementMetrics Json     @default("{}")
  lastCalculated     DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])

  @@map("learning_metrics")
}
